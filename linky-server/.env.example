# Required — get your token at https://conso.boris.sh
LINKY_TOKEN=your_jwt_token_here

# Your Linky meter PRM (14 digits)
LINKY_PRM=REDACTED_PRM

# Off-peak hours windows (format: HH:MM-HH:MM, comma-separated)
HC_WINDOWS=23:32-5:32,15:02-17:02

# Electricity pricing (€/kWh)
PRICE_HP=0.2065
PRICE_HC=0.1579
PRICE_ABO_MONTHLY=15.65

# Refresh interval in seconds (default: 1 hour)
REFRESH_INTERVAL=3600
