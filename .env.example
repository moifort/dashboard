# Required — get your token at https://conso.boris.sh
LINKY_TOKEN=your_jwt_token_here

# Your Linky meter PRM (14 digits, visible on your meter or on enedis.fr)
LINKY_PRM=your_prm_here

# Off-peak hours windows (format: HH:MM-HH:MM, comma-separated)
HC_WINDOWS=23:32-5:32,15:02-17:02

# Electricity pricing (€/kWh)
PRICE_HP=0.2065
PRICE_HC=0.1579
PRICE_ABO_MONTHLY=15.65

# Refresh interval in seconds (default: 1 hour)
REFRESH_INTERVAL=3600

# Optional — EcoFlow PowerStream solar production (private app credentials).
# When EMAIL/PASSWORD/DEVICE_SN are set, the dashboard adds a daily solar chart.
# Reported PV power is read over the private MQTT broker and integrated into
# daily kWh totals (no historical backfill; history starts at first connection).
ECOFLOW_EMAIL=your_ecoflow_account_email
ECOFLOW_PASSWORD=your_ecoflow_account_password
ECOFLOW_DEVICE_SN=your_powerstream_serial_number
# API host: api-e.ecoflow.com (EU), api.ecoflow.com (global), api-a.ecoflow.com (asia)
ECOFLOW_API_HOST=api-e.ecoflow.com
