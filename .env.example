# Required — get your token at https://conso.boris.sh
LINKY_TOKEN=your_jwt_token_here

# Your Linky meter PRM (14 digits, visible on your meter or on enedis.fr)
LINKY_PRM=your_prm_here

# Off-peak hours windows (format: HH:MM-HH:MM, comma-separated)
HC_WINDOWS=23:32-5:32,15:02-17:02

# Electricity pricing (€/kWh)
PRICE_HP=0.2065
PRICE_HC=0.1579
PRICE_ABO_MONTHLY=15.65

# Refresh interval in seconds (default: 1 hour)
REFRESH_INTERVAL=3600

# Optional — EcoFlow PowerStream solar production (private app credentials).
# When EMAIL/PASSWORD/DEVICE_SN are set, the dashboard adds a daily solar chart.
# Reported PV power is read over the private MQTT broker and integrated into
# daily kWh totals (no historical backfill; history starts at first connection).
ECOFLOW_EMAIL=your_ecoflow_account_email
ECOFLOW_PASSWORD=your_ecoflow_account_password
ECOFLOW_DEVICE_SN=your_powerstream_serial_number
# API host: api-e.ecoflow.com (EU), api.ecoflow.com (global), api-a.ecoflow.com (asia)
ECOFLOW_API_HOST=api-e.ecoflow.com

# Optional — crypto-bot stats panel (top-right). Mirrors the iOS "small" widget.
# Set the GraphQL URL to enable; leave empty to disable. On CasaOS the bot runs
# on the same host, reachable via its LAN IP (bridge network can't use localhost).
CRYPTO_API_URL=http://192.168.1.199:3003/graphql
# Bearer token (the bot's NITRO_API_TOKEN) — omit if the bot has no auth.
CRYPTO_API_TOKEN=your_crypto_bot_api_token

# Optional — water-heater (cumulus) daily consumption via Zigbee2MQTT.
# Set the MQTT host to enable; leave empty to disable. The contactor exposes
# only instantaneous power, so daily kWh are integrated from it (no backfill).
# On CasaOS, point to the broker's LAN IP (bridge network can't use localhost).
CUMULUS_MQTT_HOST=192.168.1.199
CUMULUS_MQTT_PORT=1883
CUMULUS_TOPIC=zigbee2mqtt/cumulus
# MQTT credentials — omit if the broker allows anonymous connections.
CUMULUS_MQTT_USERNAME=
CUMULUS_MQTT_PASSWORD=

# Optional — UniFi network panel (bottom-right "Réseau"). Queries the local
# gateway (UCG Ultra / UniFi OS) for internet & Wi-Fi quality, clients per SSID,
# top-3 clients per network and data usage. Set the password to enable; leave
# empty to disable. On CasaOS, use the gateway's LAN IP (bridge network).
UNIFI_HOST=https://192.168.1.1
UNIFI_USERNAME=your_gateway_local_account
UNIFI_PASSWORD=
UNIFI_SITE=default
# Your own SSID names — used to split IoT vs personal client counts and top-3 lists.
UNIFI_SSID_IOT=your_iot_wifi_ssid
UNIFI_SSID_MAIN=your_main_wifi_ssid
